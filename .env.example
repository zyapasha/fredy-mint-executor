# Optional environment configuration for mint-executor
# Copy to .env and fill in values, then `source .env` before running

# Path to GPG-encrypted wallet bundle (default: ~/.config/mint-executor/wallets.gpg)
# MINT_EXECUTOR_SECRET=

# Path to the GPG passphrase file (default: ~/.config/mint-executor/.key)
# MINT_EXECUTOR_KEY=

# Default consolidation destination (no default; required if consolidate enabled and --to not passed)
# MINT_EXECUTOR_DEFAULT_TO=0xYourColdWallet

# Custom RPCs (override built-in defaults)
# MINT_EXECUTOR_RPC_ETHEREUM=https://your.preferred.rpc
# MINT_EXECUTOR_RPC_BASE=https://mainnet.base.org
